# goals.config
#
# DOC: Checked grayscale image metadata and embedding capacity.
image_metadata_checked = matchany : string_contains : image_metadata_checked : answer=IMAGE_METADATA_OK
# DOC: Validated the seed, pair count, and pixel-pair plan.
permutation_plan_checked = matchany : string_contains : permutation_plan_checked : answer=PERMUTATION_PLAN_OK
# DOC: Created the stego image with pair-order permutation.
permutation_embed_ran = matchany : string_contains : permutation_embed_ran : answer=PERMUTATION_EMBED_OK
# DOC: Extracted the message from pixel-pair ordering.
permutation_extract_ran = matchany : string_contains : permutation_extract_ran : answer=PERMUTATION_EXTRACT_OK
# DOC: Recovered the correct secret message.
secret_recovered = matchany : string_equal : secret_recovered : answer=7aad003b360006da660f867970e3c65ee552f64de9127fad95b081e15aebe948
