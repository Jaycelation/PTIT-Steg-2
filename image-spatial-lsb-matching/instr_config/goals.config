# goals.config
#
# DOC: Checked input image metadata and matching capacity.
image_metadata_checked = matchany : string_contains : image_metadata_checked : answer=IMAGE_METADATA_OK
# DOC: Ran LSB Matching embedding and created the stego image.
matching_embed_ran = matchany : string_contains : matching_embed_ran : answer=LSB_MATCHING_EMBED_OK
# DOC: Extracted the message from LSBs after matching.
matching_extract_ran = matchany : string_contains : matching_extract_ran : answer=LSB_MATCHING_EXTRACT_OK
# DOC: Reported plus/minus changes and image quality metrics.
matching_metrics_reported = matchany : string_contains : matching_metrics_reported : answer=METRICS_OK
# DOC: Recovered the correct secret message.
secret_recovered = matchany : string_equal : secret_recovered : answer=ddf3af7daab306ea89c3005f91eaade4581e310fee2a972445951e81d2485bfb
